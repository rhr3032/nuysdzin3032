---
// Masonry Feature Grid
// ------------
// Description: A masonry grid of features

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'

// - UI
import { Image } from 'astro:assets'
import FeatureCard from '../../ui/cards/FeatureImageCard.astro'

// Content
// - Assets
import feature01Front from '../../../assets/features/masonry/feature_01_front.webp'
import feature01Back from '../../../assets/features/masonry/feature_01_back.webp'
import feature02Front from '../../../assets/features/masonry/feature_02_front.webp'
import feature02Back from '../../../assets/features/masonry/feature_02_back.webp'
import feature03Front from '../../../assets/features/masonry/feature_03_front.webp'
import feature03Back from '../../../assets/features/masonry/feature_03_back.webp'
import feature04Front from '../../../assets/features/masonry/feature_04_front.webp'
import feature04Back from '../../../assets/features/masonry/feature_04_back.webp'
---

<Section>
	<Row classes="">
		<Col span="4">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-xl">
					<h3>Team Focused</h3>
					<p>
						Our design process is built for collaboration. We work closely with your team to understand your goals, users, and brand — creating solutions that resonate.
					</p>
				</div>
				<div slot="bg-front">
					<Image
						src={feature01Front}
						alt="Team Focused"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
				<div slot="bg-back">
					<Image
						src={feature01Back}
						alt="Team Focused"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
			</FeatureCard>
		</Col>
		<Col span="8">
			<FeatureCard classes="h-full" parallaxOffset="50" style="solid" decorationType="all">
				<div slot="content" class="max-w-lg">
					<h3>Pixel-Perfect Interface Design</h3>
					<p>
						From wireframes to high-fidelity mockups, we craft interfaces that are not only visually stunning but also intuitive and user-friendly.
					</p>
				</div>
				<div slot="bg-front">
					<Image
						src={feature02Front}
						alt="Pixel-Perfect Interface Design"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
				<div slot="bg-back">
					<Image
						src={feature02Back}
						alt="Pixel-Perfect Interface Design"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
			</FeatureCard>
		</Col>
		<Col span="8">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-xl">
					<h3>Interactive Prototyping</h3>
					<p>
						Bringing designs to life with interactive prototypes that allow you to experience the user flow and interactions before development begins.
					</p>
				</div>
				<div slot="bg-front">
					<Image
						src={feature03Front}
						alt="Interactive Prototyping"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
				<div slot="bg-back">
					<Image
						src={feature03Back}
						alt="Interactive Prototyping"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
			</FeatureCard>
		</Col>
		<Col span="4">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-lg">
					<h3>Seamless Design Handoff</h3>
					<p>
						We ensure a smooth transition from design to development with detailed documentation, assets, and support to bring your project to life without a hitch.
					</p>
				</div>
				<div slot="bg-front">
					<Image
						src={feature04Front}
						alt="Seamless Design Handoff"
						loading="lazy"
						decoding="async"
						layout="constrained"
						class="feature__image"
						height={300}
					/>
				</div>
				<div slot="bg-back">
					<Image
						src={feature04Back}
						alt="Seamless Design Handoff"
						loading="lazy"
						decoding="async"
						class="feature__image"
						layout="constrained"
						height={300}
					/>
				</div>
			</FeatureCard>
		</Col>
	</Row>
</Section>

<style>
	@reference '../../../styles/global.css';
	.feature__image {
		@apply ml-auto max-w-none! lg:max-w-full!;
	}
</style>
