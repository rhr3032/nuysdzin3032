---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'

// - Blocks
import Hero from '../components/blocks/hero/SimpleHeroBasic.astro'
import ContactInfo from '../components/blocks/contact/ContactInfoCards.astro'
import ContactForm from '../components/blocks/contact/ContactForm.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title: 'Suspended Suspended | Contact',
	description:
		'Get in touch with Suspended Suspended for new projects, partnerships, or general inquiries. Let us help you create exceptional digital experiences.'
}
// - Hero data
const heroData = {
	title: 'Let\'s Create Something Remarkable',
	subtitle: 'Get in Touch',
	text: 'Whether you have a specific project in mind or just want to explore how design can help your business grow, we\'d love to hear from you.',
}
// - Contact data
const contactData = {
	title: 'Reach out to the right team for your needs.'
}
// - Brand data
const brandData = {
	title: 'Trusted by forward-thinking brands'
}
// - FAQ data
const faqData = {
	title: 'Everything you need to know',
	subtitle: 'Frequently Asked Questions'
}
// - CTA data
const ctaData = {
	title: 'Join Our Growing Team',
	text: 'We\'re always looking for talented designers, researchers, and strategists who share our passion for exceptional user experiences. Think you\'d be a great fit?',
	buttonLink: '/contact',
	buttonText: 'View Open Positions'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		text={heroData.text}
	/>
	<ContactInfo title={contactData.title} />
	<ContactForm />
	<Brand title={brandData.title} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
